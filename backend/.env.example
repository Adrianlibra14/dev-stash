# Environment — controls which sequelize-cli config block is used for migrations.
# "development" | "production"
# sequelize-cli defaults to "development" if NODE_ENV is unset.
NODE_ENV=development

# Neon PostgreSQL connection string.
# Use the DIRECT (non-pooled) endpoint — pooled connections via PgBouncer
# cause errors when running migrations.
# Format: postgresql://<user>:<password>@<host>.neon.tech/<dbname>?sslmode=require
DATABASE_URL=

# Port the Express server listens on (defaults to 3000).
PORT=
